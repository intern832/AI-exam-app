rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExistingDoc() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncomingDoc() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if signedIn()
        && userId == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && !('password' in request.resource.data)
        && !('passwordHash' in request.resource.data);

      allow read, update, delete: if signedIn() && userId == request.auth.uid;
    }

    match /exams/{examId} {
      allow create: if ownsIncomingDoc();
      allow read, update, delete: if ownsExistingDoc();
    }

    match /ques_bank/{questionId} {
      allow create: if ownsIncomingDoc();
      allow read, update, delete: if ownsExistingDoc();
    }

    match /submissions/{submissionId} {
      allow create: if ownsIncomingDoc();
      allow read, update, delete: if ownsExistingDoc();
    }
  }
}
